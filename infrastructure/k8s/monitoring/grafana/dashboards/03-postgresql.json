{
  "title": "PostgreSQL",
  "uid": "postgresql",
  "schemaVersion": 38,
  "tags": ["technomart", "postgresql"],
  "refresh": "30s",
  "time": {"from": "now-1h", "to": "now"},
  "panels": [
    {
      "id": 1,
      "title": "接続数",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [{
        "expr": "pg_stat_activity_count{datname=\"technomart\"}",
        "legendFormat": "Active Connections"
      }]
    },
    {
      "id": 2,
      "title": "PostgreSQL 死活",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "targets": [{
        "expr": "pg_up",
        "legendFormat": "Up"
      }],
      "fieldConfig": {"defaults": {"mappings": [{"type": "value", "options": {"0": {"text": "DOWN", "color": "red"}, "1": {"text": "UP", "color": "green"}}}]}}
    },
    {
      "id": 3,
      "title": "トランザクション数 (TPS)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "targets": [{
        "expr": "rate(pg_stat_database_xact_commit{datname=\"technomart\"}[5m]) + rate(pg_stat_database_xact_rollback{datname=\"technomart\"}[5m])",
        "legendFormat": "TPS"
      }],
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    },
    {
      "id": 4,
      "title": "Cache Hit 率",
      "type": "gauge",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "targets": [{
        "expr": "rate(pg_stat_database_blks_hit{datname=\"technomart\"}[5m]) / (rate(pg_stat_database_blks_hit{datname=\"technomart\"}[5m]) + rate(pg_stat_database_blks_read{datname=\"technomart\"}[5m]) + 0.001) * 100",
        "legendFormat": "Cache Hit %"
      }],
      "fieldConfig": {"defaults": {"unit": "percent", "max": 100}}
    },
    {
      "id": 5,
      "title": "接続数推移",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [{
        "expr": "pg_stat_activity_count",
        "legendFormat": "{{datname}} ({{state}})"
      }]
    },
    {
      "id": 6,
      "title": "DB サイズ",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 4},
      "targets": [{
        "expr": "pg_database_size_bytes{datname=\"technomart\"}",
        "legendFormat": "DB Size"
      }],
      "fieldConfig": {"defaults": {"unit": "bytes"}}
    }
  ]
}
