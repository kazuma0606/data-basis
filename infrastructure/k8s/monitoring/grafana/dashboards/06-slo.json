{
  "title": "SLI / SLO ダッシュボード",
  "uid": "slo-dashboard",
  "schemaVersion": 38,
  "tags": ["technomart", "slo"],
  "refresh": "5m",
  "time": {"from": "now-30d", "to": "now"},
  "panels": [
    {
      "id": 1,
      "title": "Backend API 可用性 SLO (目標: 99.5%)",
      "type": "gauge",
      "gridPos": {"h": 5, "w": 6, "x": 0, "y": 0},
      "targets": [{
        "expr": "avg_over_time(up{job=\"backend\"}[30d]) * 100",
        "legendFormat": "可用性 %"
      }],
      "fieldConfig": {"defaults": {"unit": "percent", "max": 100, "thresholds": {"steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 99}, {"color": "green", "value": 99.5}]}}}
    },
    {
      "id": 2,
      "title": "API p99 応答時間 SLO (目標: < 2s)",
      "type": "gauge",
      "gridPos": {"h": 5, "w": 6, "x": 6, "y": 0},
      "targets": [{
        "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket{job=\"backend\"}[5m]))",
        "legendFormat": "p99 latency"
      }],
      "fieldConfig": {"defaults": {"unit": "s", "thresholds": {"steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1}, {"color": "red", "value": 2}]}}}
    },
    {
      "id": 3,
      "title": "Kafka Consumer Lag SLO (目標: < 10,000)",
      "type": "gauge",
      "gridPos": {"h": 5, "w": 6, "x": 12, "y": 0},
      "targets": [{
        "expr": "sum(kafka_consumer_group_lag)",
        "legendFormat": "Total Lag"
      }],
      "fieldConfig": {"defaults": {"thresholds": {"steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 5000}, {"color": "red", "value": 10000}]}}}
    },
    {
      "id": 4,
      "title": "スコアリングバッチ成功率 SLO (目標: 99%)",
      "type": "stat",
      "gridPos": {"h": 5, "w": 6, "x": 18, "y": 0},
      "targets": [{
        "expr": "(1 - (time() - job_last_success_timestamp{job=\"scoring_batch\"}) / 90000) * 100",
        "legendFormat": "Batch Health %"
      }],
      "fieldConfig": {"defaults": {"unit": "percent"}}
    },
    {
      "id": 5,
      "title": "API エラーバジェット消化率 (30d)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 5},
      "targets": [{
        "expr": "1 - avg_over_time(up{job=\"backend\"}[30d])",
        "legendFormat": "Error Budget Burn Rate"
      }],
      "fieldConfig": {"defaults": {"unit": "percentunit"}}
    },
    {
      "id": 6,
      "title": "API レスポンス時間分布 (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 5},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket{job=\"backend\"}[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job=\"backend\"}[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket{job=\"backend\"}[5m]))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    }
  ]
}
