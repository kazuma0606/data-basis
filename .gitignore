# 接続情報（検証用）
CONNECTIONS.md

# バージョン管理DB（スキーマはgit管理、データはローカル保持）
versions/deployments.db

verification/*.db
verification/uv.lock
verification/src/__pycache__/

# Terraform（サブディレクトリを含む全階層に適用）
**/.terraform/
**/*.tfstate
**/*.tfstate.backup
**/terraform.tfvars
**/.terraform.lock.hcl

# TLS 証明書・秘密鍵（ローカル生成、共有不要）
infrastructure/k8s/ingress/*.key
infrastructure/k8s/ingress/*.crt

# Vagrant
infrastructure/vagrant/.vagrant/
infrastructure/vagrant/minimal/.vagrant/
infrastructure/vagrant/production/.vagrant/

# Frontend — Next.js
application/frontend/.next/
application/frontend/node_modules/
application/frontend/.env.local

# Backend — Python
application/backend/.venv/
application/backend/__pycache__/
application/backend/**/__pycache__/
application/backend/.env.local
application/backend/.env.host
application/backend/.env.vm
